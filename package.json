{
  "name": "mu-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --watch packages/mu-coding/bin/mu.js",
    "start": "bun packages/mu-coding/bin/mu.js",
    "lint": "biome check packages/",
    "lint:fix": "biome check --fix --unsafe packages/",
    "format": "biome format --write packages/",
    "check": "biome check packages/ && tsc -b",
    "test": "bun test packages/",
    "knip": "knip",
    "sg": "sg",
    "publish": "bun scripts/publish.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "knip": "^6.4.1",
    "typescript": "^5.8.3"
  }
}
